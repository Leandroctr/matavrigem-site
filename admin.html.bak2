<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Painel Administrativo - Aruanda de Mata Virgem</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --verde: #1b3a22;
      --verde-med: #2c5c3a;
      --verde-cl: #3d7a50;
      --dourado: #c8a84b;
      --dourado-cl: #e2c97e;
      --marrom: #7a5230;
      --marrom-cl: #a87840;
      --creme: #f6f2ea;
      --creme2: #ede8de;
      --branco: #ffffff;
      --preto: #0a0a08;
      --preto-cl: #1a1a16;
      --texto: #252520;
      --texto-cl: #56564e;
      --vermelho: #d64545;
      --verde-ok: #25d366;
    }

    body {
      font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--preto);
      color: var(--texto);
      overflow-x: hidden;
    }

    /* ══ TELA DE LOGIN ══ */
    .login-screen {
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: linear-gradient(135deg, var(--verde) 0%, var(--verde-med) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 1;
      visibility: visible;
      transition: opacity .3s, visibility .3s;
    }

    .login-screen.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .login-card {
      background: var(--creme);
      border-radius: 12px;
      padding: 3rem;
      max-width: 420px;
      width: 90%;
      box-shadow: 0 20px 60px rgba(10,10,8,.3);
      animation: slideUp .5s ease-out;
    }

    @keyframes slideUp {
      from { transform: translateY(40px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .login-card h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      color: var(--verde);
      margin-bottom: .5rem;
    }

    .login-card .subtitle {
      font-size: .85rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--dourado);
      margin-bottom: 2rem;
    }

    .login-form-group {
      margin-bottom: 1.5rem;
    }

    .login-form-group label {
      display: block;
      font-size: .8rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--verde);
      margin-bottom: .6rem;
      font-weight: 500;
    }

    .login-form-group input {
      width: 100%;
      padding: 1rem;
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 6px;
      font-family: inherit;
      font-size: 1rem;
      color: var(--texto);
      background: var(--branco);
      transition: border-color .3s;
    }

    .login-form-group input:focus {
      outline: none;
      border-color: var(--dourado);
      box-shadow: 0 0 0 3px rgba(200,168,75,.1);
    }

    .login-btn {
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, var(--verde) 0%, var(--verde-med) 100%);
      color: var(--branco);
      border: none;
      border-radius: 6px;
      font-size: .85rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-weight: 500;
      cursor: pointer;
      transition: all .3s;
      margin-bottom: 1rem;
    }

    .login-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(27,58,34,.3);
    }

    .login-btn:disabled {
      opacity: .6;
      cursor: not-allowed;
    }

    .login-toggle {
      text-align: center;
      font-size: .85rem;
      color: var(--texto-cl);
    }

    .login-toggle button {
      background: none;
      border: none;
      color: var(--dourado);
      cursor: pointer;
      text-decoration: underline;
      font-weight: 500;
    }

    .login-toggle button:hover {
      color: var(--dourado-cl);
    }

    .login-error {
      color: var(--vermelho);
      font-size: .8rem;
      margin-top: .5rem;
      display: none;
      padding: .8rem;
      background: rgba(214,69,69,.1);
      border: 1px solid rgba(214,69,69,.3);
      border-radius: 4px;
    }

    .login-error.show {
      display: block;
    }

    .login-loading {
      display: none;
      text-align: center;
      color: var(--dourado);
      font-size: .8rem;
    }

    .login-loading.show {
      display: block;
    }

    /* ══ HEADER ══ */
    .adm-header {
      background: linear-gradient(135deg, var(--verde) 0%, var(--verde-med) 100%);
      padding: 2rem;
      color: var(--branco);
      border-bottom: 1px solid rgba(200,168,75,.2);
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .adm-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 300;
    }

    .adm-header-sub {
      font-size: .75rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--dourado-cl);
      margin-top: .3rem;
    }

    .adm-header-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .sync-status {
      display: flex;
      align-items: center;
      gap: .6rem;
      padding: .6rem 1.2rem;
      background: rgba(200,168,75,.15);
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 20px;
      font-size: .75rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--dourado-cl);
    }

    .sync-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--verde-ok);
      animation: pulse 2s ease-in-out infinite;
    }

    .sync-dot.error {
      background: var(--vermelho);
      animation: none;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .5; }
    }

    .adm-logout {
      background: rgba(200,168,75,.2);
      border: 1px solid rgba(200,168,75,.4);
      color: var(--dourado-cl);
      padding: .7rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: .75rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      transition: all .3s;
      border: none;
      font-weight: 500;
    }

    .adm-logout:hover {
      background: rgba(200,168,75,.3);
      border-color: rgba(200,168,75,.6);
    }

    /* ══ CONTAINER ══ */
    .adm-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }

    /* ══ TABS ══ */
    .adm-tabs {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(200,168,75,.2);
      flex-wrap: wrap;
    }

    .adm-tab {
      padding: 1rem 1.5rem;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--texto-cl);
      cursor: pointer;
      font-size: .85rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      transition: all .3s;
    }

    .adm-tab:hover {
      color: var(--dourado);
    }

    .adm-tab.active {
      color: var(--dourado);
      border-bottom-color: var(--dourado);
    }

    /* ══ CONTEÚDO ══ */
    .adm-content {
      display: none;
      animation: fadeIn .3s;
    }

    .adm-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ══ FORMULÁRIO ══ */
    .adm-form {
      background: var(--creme);
      border: 1px solid rgba(200,168,75,.2);
      border-radius: 6px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .adm-form-group {
      margin-bottom: 1.5rem;
    }

    .adm-form-group label {
      display: block;
      font-size: .8rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--verde);
      margin-bottom: .5rem;
      font-weight: 500;
    }

    .adm-form-group input,
    .adm-form-group textarea {
      width: 100%;
      padding: .8rem;
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 4px;
      font-family: inherit;
      font-size: .95rem;
      color: var(--texto);
      background: var(--branco);
      transition: border-color .3s;
    }

    .adm-form-group input:focus,
    .adm-form-group textarea:focus {
      outline: none;
      border-color: var(--dourado);
      box-shadow: 0 0 0 3px rgba(200,168,75,.1);
    }

    .adm-form-group textarea {
      resize: vertical;
      min-height: 100px;
    }

    /* ══ BOTÕES ══ */
    .adm-btn {
      padding: .8rem 1.8rem;
      border: none;
      border-radius: 4px;
      font-size: .8rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all .3s;
      font-weight: 500;
    }

    .adm-btn-primary {
      background: var(--verde);
      color: var(--branco);
    }

    .adm-btn-primary:hover:not(:disabled) {
      background: var(--verde-med);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(27,58,34,.3);
    }

    .adm-btn-secondary {
      background: var(--dourado);
      color: var(--verde);
    }

    .adm-btn-secondary:hover:not(:disabled) {
      background: var(--dourado-cl);
      transform: translateY(-2px);
    }

    .adm-btn-danger {
      background: var(--vermelho);
      color: var(--branco);
    }

    .adm-btn-danger:hover:not(:disabled) {
      background: #c93636;
      transform: translateY(-2px);
    }

    .adm-btn:disabled {
      opacity: .6;
      cursor: not-allowed;
    }

    .adm-btn-small {
      padding: .6rem 1.2rem;
      font-size: .75rem;
    }

    /* ══ ITENS ══ */
    .adm-item {
      background: var(--creme);
      border: 1px solid rgba(200,168,75,.2);
      border-radius: 4px;
      padding: 1.5rem;
      margin-bottom: 1.2rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .adm-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 3px;
      background: var(--dourado);
      opacity: 0;
      transition: opacity .3s;
    }

    .adm-item:hover::before {
      opacity: 1;
    }

    .adm-item-info {
      flex: 1;
      position: relative;
      z-index: 1;
    }

    .adm-item-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      color: var(--verde);
      margin-bottom: .3rem;
    }

    .adm-item-meta {
      font-size: .8rem;
      color: var(--texto-cl);
    }

    .adm-item-actions {
      display: flex;
      gap: .6rem;
      position: relative;
      z-index: 1;
    }

    /* ══ ALERT ══ */
    .adm-alert {
      padding: 1rem;
      border-radius: 4px;
      margin-bottom: 1.5rem;
      font-size: .9rem;
      animation: slideDown .3s;
      display: flex;
      align-items: center;
      gap: .8rem;
    }

    @keyframes slideDown {
      from { transform: translateY(-20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .adm-alert-success {
      background: rgba(37,211,102,.1);
      border: 1px solid rgba(37,211,102,.3);
      color: #1a7d4e;
    }

    .adm-alert-error {
      background: rgba(214,69,69,.1);
      border: 1px solid rgba(214,69,69,.3);
      color: #9a2c2c;
    }

    .adm-alert-warning {
      background: rgba(200,168,75,.1);
      border: 1px solid rgba(200,168,75,.3);
      color: #7a5230;
    }

    .adm-alert-icon {
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    /* ══ GRID ══ */
    .adm-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .adm-grid-2 {
        grid-template-columns: 1fr;
      }
      .adm-header {
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
      }
      .adm-header-actions {
        width: 100%;
        flex-wrap: wrap;
      }
      .sync-status {
        flex: 1;
      }
    }

    /* ══ MODAL ══ */
    .adm-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10,10,8,.7);
      z-index: 200;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(4px);
    }

    .adm-modal.open {
      display: flex;
    }

    .adm-modal-content {
      background: var(--creme);
      border-radius: 6px;
      padding: 2rem;
      max-width: 500px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
      animation: modalOpen .3s;
      position: relative;
    }

    @keyframes modalOpen {
      from { transform: scale(.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .adm-modal-header {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      color: var(--verde);
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(200,168,75,.2);
    }

    .adm-modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 2rem;
      color: var(--texto-cl);
      cursor: pointer;
      transition: color .2s;
      line-height: 1;
    }

    .adm-modal-close:hover {
      color: var(--dourado);
    }

    .info-box {
      background: rgba(200,168,75,.1);
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 4px;
      padding: 1rem;
      margin-bottom: 1.5rem;
      font-size: .9rem;
      line-height: 1.6;
      color: var(--texto);
    }
  </style>
</head>
<body>

  <!-- TELA DE LOGIN -->
  <div class="login-screen" id="loginScreen">
    <div class="login-card">
      <h1>Aruanda</h1>
      <div class="subtitle">Painel Administrativo</div>

      <div class="info-box">
        ℹ️ Se é a primeira vez, clique em "Criar nova conta". Se já tem conta criada no Firebase, use o email e senha.
      </div>

      <div id="loginForm">
        <div class="login-form-group">
          <label for="loginEmail">Email</label>
          <input type="email" id="loginEmail" placeholder="seu@email.com" />
        </div>
        <div class="login-form-group">
          <label for="loginPassword">Senha</label>
          <input type="password" id="loginPassword" placeholder="Digite sua senha" />
        </div>
        <button class="login-btn" onclick="fazerLogin()" id="loginBtn">Entrar</button>
        <div class="login-loading" id="loginLoading">⏳ Autenticando...</div>
        <div class="login-error" id="loginError"></div>
        <div class="login-toggle">
          Não tem conta? <button onclick="toggleRegistro()">Criar nova conta</button>
        </div>
      </div>

      <div id="registroForm" style="display: none;">
        <div class="login-form-group">
          <label for="registroEmail">Email</label>
          <input type="email" id="registroEmail" placeholder="seu@email.com" />
        </div>
        <div class="login-form-group">
          <label for="registroPassword">Senha (mín. 6 caracteres)</label>
          <input type="password" id="registroPassword" placeholder="Crie uma senha" />
        </div>
        <div class="login-form-group">
          <label for="registroPasswordConfirm">Confirmar Senha</label>
          <input type="password" id="registroPasswordConfirm" placeholder="Confirme a senha" />
        </div>
        <button class="login-btn" onclick="fazerRegistro()" id="registroBtn">Criar Conta</button>
        <div class="login-loading" id="registroLoading">⏳ Criando conta...</div>
        <div class="login-error" id="registroError"></div>
        <div class="login-toggle">
          Já tem conta? <button onclick="toggleRegistro()">Voltar para login</button>
        </div>
      </div>
    </div>
  </div>

  <!-- HEADER -->
  <div class="adm-header" id="adminHeader" style="display: none;">
    <div>
      <h1>Painel Administrativo</h1>
      <div class="adm-header-sub">Templo Escola Aruanda de Mata Virgem</div>
    </div>
    <div class="adm-header-actions">
      <div class="sync-status" id="syncStatus">
        <div class="sync-dot" id="syncDot"></div>
        <span id="syncText">Conectado</span>
      </div>
      <button class="adm-logout" onclick="fazerLogout()">Sair</button>
    </div>
  </div>

  <div class="adm-container" id="adminContainer" style="display: none;">

    <!-- TABS -->
    <div class="adm-tabs">
      <button class="adm-tab active" onclick="mudarTab('eventos')">📅 Eventos</button>
      <button class="adm-tab" onclick="mudarTab('proxima')">🎭 Próxima Gira</button>
      <button class="adm-tab" onclick="mudarTab('galeria')">🖼️ Galeria</button>
      <button class="adm-tab" onclick="mudarTab('cursos')">📚 Cursos</button>
    </div>

    <!-- EVENTOS -->
    <div id="tab-eventos" class="adm-content active">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--verde); margin-bottom: 1.5rem;">Gerenciar Eventos</h2>

      <div class="adm-form">
        <h3 style="color: var(--verde); margin-bottom: 1.5rem; font-family: 'Cormorant Garamond', serif; font-size: 1.3rem;">Adicionar Novo Evento</h3>
        <div class="adm-grid-2">
          <div class="adm-form-group">
            <label>Dia (ex: 17)</label>
            <input type="text" id="newEvtDia" placeholder="17" maxlength="2"/>
          </div>
          <div class="adm-form-group">
            <label>Mês (ex: Abr)</label>
            <input type="text" id="newEvtMes" placeholder="Abr" maxlength="3"/>
          </div>
          <div class="adm-form-group">
            <label>Semana (ex: Sexta-feira)</label>
            <input type="text" id="newEvtSemana" placeholder="Sexta-feira"/>
          </div>
          <div class="adm-form-group">
            <label>Hora (ex: 20h30)</label>
            <input type="text" id="newEvtHora" placeholder="20h30" maxlength="5"/>
          </div>
        </div>
        <div class="adm-form-group">
          <label>Nome do Evento</label>
          <input type="text" id="newEvtNome" placeholder="Ex: Baianos e Boiadeiros"/>
        </div>
        <button class="adm-btn adm-btn-primary" onclick="adicionarEvento()">+ Adicionar Evento</button>
      </div>

      <div id="listaEventos"></div>
    </div>

    <!-- PRÓXIMA GIRA -->
    <div id="tab-proxima" class="adm-content">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--verde); margin-bottom: 1.5rem;">Próxima Gira</h2>

      <div class="adm-form">
        <div class="adm-form-group">
          <label>Data (ex: 17/04)</label>
          <input type="text" id="proxData" placeholder="17/04"/>
        </div>
        <div class="adm-form-group">
          <label>Dia da Semana</label>
          <input type="text" id="proxDia" placeholder="Sexta-feira"/>
        </div>
        <div class="adm-form-group">
          <label>Hora</label>
          <input type="text" id="proxHora" placeholder="20h30"/>
        </div>
        <div class="adm-form-group">
          <label>Nome da Gira</label>
          <input type="text" id="proxNome" placeholder="Baianos e Boiadeiros"/>
        </div>
        <div class="adm-form-group">
          <label>Descrição</label>
          <textarea id="proxDesc" placeholder="Descreva a gira..."></textarea>
        </div>
        <div class="adm-form-group">
          <label>URL da Imagem</label>
          <input type="text" id="proxImg" placeholder="https://matavirgem.org/proxima.jpg"/>
        </div>
        <button class="adm-btn adm-btn-primary" onclick="salvarProxima()">💾 Salvar Próxima Gira</button>
      </div>
    </div>

    <!-- GALERIA -->
    <div id="tab-galeria" class="adm-content">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--verde); margin-bottom: 1.5rem;">Gerenciar Galeria</h2>

      <div class="adm-form">
        <h3 style="color: var(--verde); margin-bottom: 1.5rem; font-family: 'Cormorant Garamond', serif; font-size: 1.3rem;">Adicionar Foto</h3>
        <div class="adm-form-group">
          <label>Título da Foto</label>
          <input type="text" id="newFotoTitulo" placeholder="Ex: Altar"/>
        </div>
        <div class="adm-form-group">
          <label>URL da Imagem</label>
          <input type="text" id="newFotoUrl" placeholder="https://matavirgem.org/foto.jpeg"/>
        </div>
        <button class="adm-btn adm-btn-primary" onclick="adicionarFoto()">+ Adicionar Foto</button>
      </div>

      <div id="listaFotos"></div>
    </div>

    <!-- CURSOS -->
    <div id="tab-cursos" class="adm-content">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--verde); margin-bottom: 1.5rem;">Gerenciar Cursos</h2>

      <div class="adm-form">
        <h3 style="color: var(--verde); margin-bottom: 1.5rem; font-family: 'Cormorant Garamond', serif; font-size: 1.3rem;">Adicionar Aula</h3>
        <div class="adm-form-group">
          <label>Número da Aula</label>
          <input type="number" id="newAulaNumero" placeholder="1" min="1"/>
        </div>
        <div class="adm-form-group">
          <label>Título da Aula</label>
          <input type="text" id="newAulaTitulo" placeholder="Ex: Introdução à Mediunidade"/>
        </div>
        <div class="adm-form-group">
          <label>ID do Vídeo YouTube</label>
          <input type="text" id="newAulaYoutube" placeholder="dQw4w9WgXcQ"/>
        </div>
        <button class="adm-btn adm-btn-primary" onclick="adicionarAula()">+ Adicionar Aula</button>
      </div>

      <div id="listaAulas"></div>
    </div>

  </div>

  <!-- MODAL EDITAR EVENTO -->
  <div id="modalEvento" class="adm-modal" onclick="if(event.target===this) fecharModal('modalEvento')">
    <button class="adm-modal-close" onclick="fecharModal('modalEvento')">×</button>
    <div class="adm-modal-content" onclick="event.stopPropagation()">
      <div class="adm-modal-header">Editar Evento</div>
      <div class="adm-form-group">
        <label>Dia</label>
        <input type="text" id="editEvtDia" maxlength="2"/>
      </div>
      <div class="adm-form-group">
        <label>Mês</label>
        <input type="text" id="editEvtMes" maxlength="3"/>
      </div>
      <div class="adm-form-group">
        <label>Semana</label>
        <input type="text" id="editEvtSemana"/>
      </div>
      <div class="adm-form-group">
        <label>Hora</label>
        <input type="text" id="editEvtHora" maxlength="5"/>
      </div>
      <div class="adm-form-group">
        <label>Nome</label>
        <input type="text" id="editEvtNome"/>
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 2rem;">
        <button class="adm-btn adm-btn-primary" style="flex: 1;" onclick="salvarEdicaoEvento()">Salvar</button>
        <button class="adm-btn" style="flex: 1; background: var(--texto-cl); color: var(--branco);" onclick="fecharModal('modalEvento')">Cancelar</button>
      </div>
    </div>
  </div>

  <!-- MODAL EDITAR FOTO -->
  <div id="modalFoto" class="adm-modal" onclick="if(event.target===this) fecharModal('modalFoto')">
    <button class="adm-modal-close" onclick="fecharModal('modalFoto')">×</button>
    <div class="adm-modal-content" onclick="event.stopPropagation()">
      <div class="adm-modal-header">Editar Foto</div>
      <div class="adm-form-group">
        <label>Título</label>
        <input type="text" id="editFotoTitulo"/>
      </div>
      <div class="adm-form-group">
        <label>URL</label>
        <input type="text" id="editFotoUrl"/>
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 2rem;">
        <button class="adm-btn adm-btn-primary" style="flex: 1;" onclick="salvarEdicaoFoto()">Salvar</button>
        <button class="adm-btn" style="flex: 1; background: var(--texto-cl); color: var(--branco);" onclick="fecharModal('modalFoto')">Cancelar</button>
      </div>
    </div>
  </div>

  <!-- MODAL EDITAR AULA -->
  <div id="modalAula" class="adm-modal" onclick="if(event.target===this) fecharModal('modalAula')">
    <button class="adm-modal-close" onclick="fecharModal('modalAula')">×</button>
    <div class="adm-modal-content" onclick="event.stopPropagation()">
      <div class="adm-modal-header">Editar Aula</div>
      <div class="adm-form-group">
        <label>Número</label>
        <input type="number" id="editAulaNumero" min="1"/>
      </div>
      <div class="adm-form-group">
        <label>Título</label>
        <input type="text" id="editAulaTitulo"/>
      </div>
      <div class="adm-form-group">
        <label>ID YouTube</label>
        <input type="text" id="editAulaYoutube"/>
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 2rem;">
        <button class="adm-btn adm-btn-primary" style="flex: 1;" onclick="salvarEdicaoAula()">Salvar</button>
        <button class="adm-btn" style="flex: 1; background: var(--texto-cl); color: var(--branco);" onclick="fecharModal('modalAula')">Cancelar</button>
      </div>
    </div>
  </div>

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-app.js";
    import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-auth.js";
    import { getFirestore, collection, doc, setDoc, getDocs, deleteDoc, onSnapshot, query, orderBy } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-firestore.js";

    // Firebase Config
    const firebaseConfig = {
      apiKey: "AIzaSyCDt7n4hoxQlF0BRLWB_bBouO4A35YsZVY",
      authDomain: "mata-virgem.firebaseapp.com",
      projectId: "mata-virgem",
      storageBucket: "mata-virgem.firebasestorage.app",
      messagingSenderId: "351134240123",
      appId: "1:351134240123:web:86a041fee58b856ea3c1de",
      measurementId: "G-KM7DHTH737"
    };

    // Initialize Firebase
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const db = getFirestore(app);

    // Global vars
    let usuario = null;
    let dados = { eventos: [], proximaGira: {}, galeria: [], cursos: [] };
    let eventoEmEdicao = null;
    let fotoEmEdicao = null;
    let aulaEmEdicao = null;

    // ══ AUTENTICAÇÃO ══
    window.fazerLogin = async function() {
      const email = document.getElementById('loginEmail').value.trim();
      const password = document.getElementById('loginPassword').value;
      const btn = document.getElementById('loginBtn');
      const loading = document.getElementById('loginLoading');
      const error = document.getElementById('loginError');

      if (!email || !password) {
        mostrarErroLogin('❌ Preencha todos os campos');
        return;
      }

      btn.disabled = true;
      loading.classList.add('show');
      error.classList.remove('show');

      try {
        await signInWithEmailAndPassword(auth, email, password);
        // onAuthStateChanged vai detectar e atualizar a tela
      } catch (erro) {
        btn.disabled = false;
        loading.classList.remove('show');
        
        let msg = 'Erro ao fazer login';
        console.error('Erro login:', erro.code, erro.message);
        
        if (erro.code === 'auth/user-not-found') msg = 'Usuário não encontrado. Crie uma nova conta!';
        if (erro.code === 'auth/wrong-password') msg = 'Senha incorreta';
        if (erro.code === 'auth/invalid-email') msg = 'Email inválido';
        if (erro.code === 'auth/invalid-credential') msg = 'Email ou senha incorretos';
        
        mostrarErroLogin(msg);
      }
    };

    window.fazerRegistro = async function() {
      const email = document.getElementById('registroEmail').value.trim();
      const password = document.getElementById('registroPassword').value;
      const confirm = document.getElementById('registroPasswordConfirm').value;
      const btn = document.getElementById('registroBtn');
      const loading = document.getElementById('registroLoading');
      const error = document.getElementById('registroError');

      if (!email || !password || !confirm) {
        mostrarErroRegistro('❌ Preencha todos os campos');
        return;
      }

      if (password !== confirm) {
        mostrarErroRegistro('❌ As senhas não coincidem');
        return;
      }

      if (password.length < 6) {
        mostrarErroRegistro('❌ A senha deve ter pelo menos 6 caracteres');
        return;
      }

      btn.disabled = true;
      loading.classList.add('show');
      error.classList.remove('show');

      try {
        const result = await createUserWithEmailAndPassword(auth, email, password);
        console.log('Conta criada:', result.user.email);
        // onAuthStateChanged vai detectar e atualizar a tela
      } catch (erro) {
        btn.disabled = false;
        loading.classList.remove('show');
        
        let msg = 'Erro ao criar conta';
        console.error('Erro registro:', erro.code, erro.message);
        
        if (erro.code === 'auth/email-already-in-use') msg = 'Email já registrado';
        if (erro.code === 'auth/invalid-email') msg = 'Email inválido';
        
        mostrarErroRegistro(msg);
      }
    };

    window.fazerLogout = async function() {
      if (confirm('Tem certeza que deseja sair?')) {
        await signOut(auth);
      }
    };

    window.toggleRegistro = function() {
      const login = document.getElementById('loginForm');
      const registro = document.getElementById('registroForm');
      login.style.display = login.style.display === 'none' ? 'block' : 'none';
      registro.style.display = registro.style.display === 'none' ? 'block' : 'none';

      // Limpar erros
      document.getElementById('loginError').classList.remove('show');
      document.getElementById('registroError').classList.remove('show');
      document.getElementById('loginBtn').disabled = false;
      document.getElementById('registroBtn').disabled = false;
      document.getElementById('loginLoading').classList.remove('show');
      document.getElementById('registroLoading').classList.remove('show');
    };

    function mostrarErroLogin(msg) {
      const error = document.getElementById('loginError');
      error.innerHTML = msg;
      error.classList.add('show');
    }

    function mostrarErroRegistro(msg) {
      const error = document.getElementById('registroError');
      error.innerHTML = msg;
      error.classList.add('show');
    }

    // ══ CARREGAR DADOS DO FIRESTORE ══
    async function carregarDados() {
      try {
        // Eventos
        const eventosRef = collection(db, 'eventos');
        const qEventos = query(eventosRef, orderBy('dia', 'asc'));
        
        onSnapshot(qEventos, (snapshot) => {
          dados.eventos = [];
          snapshot.forEach((doc) => {
            dados.eventos.push({ id: doc.id, ...doc.data() });
          });
          renderizarEventos();
        });

        // Próxima Gira
        const qProxima = query(collection(db, 'proximaGira'));
        onSnapshot(qProxima, (snapshot) => {
          if (!snapshot.empty) {
            dados.proximaGira = snapshot.docs[0].data();
            renderizarProxima();
          }
        });

        // Galeria
        const qGaleria = query(collection(db, 'galeria'));
        onSnapshot(qGaleria, (snapshot) => {
          dados.galeria = [];
          snapshot.forEach((doc) => {
            dados.galeria.push({ id: doc.id, ...doc.data() });
          });
          renderizarFotos();
        });

        // Cursos
        const qCursos = query(collection(db, 'cursos'));
        onSnapshot(qCursos, (snapshot) => {
          if (!snapshot.empty) {
            const curso = snapshot.docs[0].data();
            if (curso.aulas) {
              dados.cursos = curso.aulas;
              renderizarAulas();
            }
          }
        });

        atualizarSyncStatus(true);
      } catch (erro) {
        console.error('Erro ao carregar:', erro);
        atualizarSyncStatus(false);
      }
    }

    // ══ OBSERVAR AUTENTICAÇÃO ══
    onAuthStateChanged(auth, (user) => {
      if (user) {
        usuario = user;
        console.log('Usuário autenticado:', user.email);
        document.getElementById('loginScreen').classList.add('hidden');
        document.getElementById('adminHeader').style.display = 'flex';
        document.getElementById('adminContainer').style.display = 'block';
        carregarDados();
      } else {
        usuario = null;
        console.log('Usuário desconectado');
        document.getElementById('loginScreen').classList.remove('hidden');
        document.getElementById('adminHeader').style.display = 'none';
        document.getElementById('adminContainer').style.display = 'none';
        // Limpar formulário
        document.getElementById('loginEmail').value = '';
        document.getElementById('loginPassword').value = '';
        document.getElementById('registroEmail').value = '';
        document.getElementById('registroPassword').value = '';
        document.getElementById('registroPasswordConfirm').value = '';
      }
    });

    // ══ EVENTOS ══
    window.renderizarEventos = function() {
      const container = document.getElementById('listaEventos');
      container.innerHTML = dados.eventos.map(evt => `
        <div class="adm-item">
          <div class="adm-item-info">
            <div class="adm-item-title">${evt.nome}</div>
            <div class="adm-item-meta">${evt.dia}/${evt.mes} • ${evt.semana} • ${evt.hora}</div>
          </div>
          <div class="adm-item-actions">
            <button class="adm-btn adm-btn-secondary adm-btn-small" onclick="editarEvento('${evt.id}')">Editar</button>
            <button class="adm-btn adm-btn-danger adm-btn-small" onclick="removerEvento('${evt.id}')">Remover</button>
          </div>
        </div>
      `).join('');
    };

    window.adicionarEvento = async function() {
      const dia = document.getElementById('newEvtDia').value.trim();
      const mes = document.getElementById('newEvtMes').value.trim();
      const semana = document.getElementById('newEvtSemana').value.trim();
      const hora = document.getElementById('newEvtHora').value.trim();
      const nome = document.getElementById('newEvtNome').value.trim();

      if (!dia || !mes || !semana || !hora || !nome) {
        mostrarAlerta('❌ Preencha todos os campos!', 'error');
        return;
      }

      try {
        const novoId = Date.now().toString();
        await setDoc(doc(db, 'eventos', novoId), { dia, mes, semana, nome, hora });

        document.getElementById('newEvtDia').value = '';
        document.getElementById('newEvtMes').value = '';
        document.getElementById('newEvtSemana').value = '';
        document.getElementById('newEvtHora').value = '';
        document.getElementById('newEvtNome').value = '';

        mostrarAlerta('✅ Evento adicionado!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao adicionar evento', 'error');
      }
    };

    window.editarEvento = function(id) {
      eventoEmEdicao = dados.eventos.find(e => e.id === id);
      if (!eventoEmEdicao) return;

      document.getElementById('editEvtDia').value = eventoEmEdicao.dia;
      document.getElementById('editEvtMes').value = eventoEmEdicao.mes;
      document.getElementById('editEvtSemana').value = eventoEmEdicao.semana;
      document.getElementById('editEvtHora').value = eventoEmEdicao.hora;
      document.getElementById('editEvtNome').value = eventoEmEdicao.nome;

      abrirModal('modalEvento');
    };

    window.salvarEdicaoEvento = async function() {
      try {
        await setDoc(doc(db, 'eventos', eventoEmEdicao.id), {
          dia: document.getElementById('editEvtDia').value,
          mes: document.getElementById('editEvtMes').value,
          semana: document.getElementById('editEvtSemana').value,
          hora: document.getElementById('editEvtHora').value,
          nome: document.getElementById('editEvtNome').value
        });

        fecharModal('modalEvento');
        mostrarAlerta('✅ Evento atualizado!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao salvar', 'error');
      }
    };

    window.removerEvento = async function(id) {
      if (confirm('Tem certeza que quer remover este evento?')) {
        try {
          await deleteDoc(doc(db, 'eventos', id));
          mostrarAlerta('✅ Evento removido!', 'success');
        } catch (erro) {
          console.error('Erro:', erro);
          mostrarAlerta('❌ Erro ao remover', 'error');
        }
      }
    };

    // ══ PRÓXIMA GIRA ══
    window.renderizarProxima = function() {
      const prox = dados.proximaGira;
      if (prox) {
        document.getElementById('proxData').value = prox.data || '';
        document.getElementById('proxDia').value = prox.dia || '';
        document.getElementById('proxHora').value = prox.hora || '';
        document.getElementById('proxNome').value = prox.nome || '';
        document.getElementById('proxDesc').value = prox.descricao || '';
        document.getElementById('proxImg').value = prox.imagem || '';
      }
    };

    window.salvarProxima = async function() {
      try {
        const docRef = doc(db, 'proximaGira', 'gira1');
        await setDoc(docRef, {
          data: document.getElementById('proxData').value,
          dia: document.getElementById('proxDia').value,
          hora: document.getElementById('proxHora').value,
          nome: document.getElementById('proxNome').value,
          descricao: document.getElementById('proxDesc').value,
          imagem: document.getElementById('proxImg').value
        });
        mostrarAlerta('✅ Próxima gira atualizada!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao salvar', 'error');
      }
    };

    // ══ GALERIA ══
    window.renderizarFotos = function() {
      const container = document.getElementById('listaFotos');
      container.innerHTML = dados.galeria.map(foto => `
        <div class="adm-item">
          <div class="adm-item-info">
            <div class="adm-item-title">${foto.titulo}</div>
            <div class="adm-item-meta">${foto.url.substring(0, 50)}...</div>
          </div>
          <div class="adm-item-actions">
            <button class="adm-btn adm-btn-secondary adm-btn-small" onclick="editarFoto('${foto.id}')">Editar</button>
            <button class="adm-btn adm-btn-danger adm-btn-small" onclick="removerFoto('${foto.id}')">Remover</button>
          </div>
        </div>
      `).join('');
    };

    window.adicionarFoto = async function() {
      const titulo = document.getElementById('newFotoTitulo').value.trim();
      const url = document.getElementById('newFotoUrl').value.trim();

      if (!titulo || !url) {
        mostrarAlerta('❌ Preencha todos os campos!', 'error');
        return;
      }

      try {
        const novoId = Date.now().toString();
        await setDoc(doc(db, 'galeria', novoId), { titulo, url });

        document.getElementById('newFotoTitulo').value = '';
        document.getElementById('newFotoUrl').value = '';

        mostrarAlerta('✅ Foto adicionada!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao adicionar foto', 'error');
      }
    };

    window.editarFoto = function(id) {
      fotoEmEdicao = dados.galeria.find(f => f.id === id);
      if (!fotoEmEdicao) return;

      document.getElementById('editFotoTitulo').value = fotoEmEdicao.titulo;
      document.getElementById('editFotoUrl').value = fotoEmEdicao.url;

      abrirModal('modalFoto');
    };

    window.salvarEdicaoFoto = async function() {
      try {
        await setDoc(doc(db, 'galeria', fotoEmEdicao.id), {
          titulo: document.getElementById('editFotoTitulo').value,
          url: document.getElementById('editFotoUrl').value
        });

        fecharModal('modalFoto');
        mostrarAlerta('✅ Foto atualizada!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao salvar', 'error');
      }
    };

    window.removerFoto = async function(id) {
      if (confirm('Tem certeza que quer remover esta foto?')) {
        try {
          await deleteDoc(doc(db, 'galeria', id));
          mostrarAlerta('✅ Foto removida!', 'success');
        } catch (erro) {
          console.error('Erro:', erro);
          mostrarAlerta('❌ Erro ao remover', 'error');
        }
      }
    };

    // ══ CURSOS ══
    window.renderizarAulas = function() {
      const container = document.getElementById('listaAulas');
      container.innerHTML = dados.cursos.map((aula, idx) => `
        <div class="adm-item">
          <div class="adm-item-info">
            <div class="adm-item-title">Aula ${aula.numero} - ${aula.titulo}</div>
            <div class="adm-item-meta">YouTube: ${aula.youtube}</div>
          </div>
          <div class="adm-item-actions">
            <button class="adm-btn adm-btn-secondary adm-btn-small" onclick="editarAula(${idx})">Editar</button>
            <button class="adm-btn adm-btn-danger adm-btn-small" onclick="removerAula(${idx})">Remover</button>
          </div>
        </div>
      `).join('');
    };

    window.adicionarAula = async function() {
      const numero = document.getElementById('newAulaNumero').value;
      const titulo = document.getElementById('newAulaTitulo').value.trim();
      const youtube = document.getElementById('newAulaYoutube').value.trim();

      if (!numero || !titulo || !youtube) {
        mostrarAlerta('❌ Preencha todos os campos!', 'error');
        return;
      }

      try {
        const novasAulas = [...dados.cursos, { numero: parseInt(numero), titulo, youtube }];
        await setDoc(doc(db, 'cursos', 'curso1'), { aulas: novasAulas });

        document.getElementById('newAulaNumero').value = '';
        document.getElementById('newAulaTitulo').value = '';
        document.getElementById('newAulaYoutube').value = '';

        mostrarAlerta('✅ Aula adicionada!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao adicionar aula', 'error');
      }
    };

    window.editarAula = function(idx) {
      aulaEmEdicao = idx;
      const aula = dados.cursos[idx];

      document.getElementById('editAulaNumero').value = aula.numero;
      document.getElementById('editAulaTitulo').value = aula.titulo;
      document.getElementById('editAulaYoutube').value = aula.youtube;

      abrirModal('modalAula');
    };

    window.salvarEdicaoAula = async function() {
      try {
        const novasAulas = [...dados.cursos];
        novasAulas[aulaEmEdicao] = {
          numero: parseInt(document.getElementById('editAulaNumero').value),
          titulo: document.getElementById('editAulaTitulo').value,
          youtube: document.getElementById('editAulaYoutube').value
        };

        await setDoc(doc(db, 'cursos', 'curso1'), { aulas: novasAulas });

        fecharModal('modalAula');
        mostrarAlerta('✅ Aula atualizada!', 'success');
      } catch (erro) {
        console.error('Erro:', erro);
        mostrarAlerta('❌ Erro ao salvar', 'error');
      }
    };

    window.removerAula = async function(idx) {
      if (confirm('Tem certeza que quer remover esta aula?')) {
        try {
          const novasAulas = dados.cursos.filter((_, i) => i !== idx);
          await setDoc(doc(db, 'cursos', 'curso1'), { aulas: novasAulas });
          mostrarAlerta('✅ Aula removida!', 'success');
        } catch (erro) {
          console.error('Erro:', erro);
          mostrarAlerta('❌ Erro ao remover', 'error');
        }
      }
    };

    // ══ UI ══
    window.mudarTab = function(tab) {
      document.querySelectorAll('.adm-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.adm-tab').forEach(el => el.classList.remove('active'));

      document.getElementById('tab-' + tab).classList.add('active');
      event.target.classList.add('active');
    };

    window.abrirModal = function(id) {
      document.getElementById(id).classList.add('open');
    };

    window.fecharModal = function(id) {
      document.getElementById(id).classList.remove('open');
    };

    window.mostrarAlerta = function(msg, tipo) {
      const container = document.querySelector('.adm-container');
      if (!container) return;
      
      const alerta = document.createElement('div');
      alerta.className = `adm-alert adm-alert-${tipo}`;
      
      let icon = '✅';
      if (tipo === 'error') icon = '❌';
      if (tipo === 'warning') icon = '⚠️';

      alerta.innerHTML = `<span class="adm-alert-icon">${icon}</span><span>${msg}</span>`;
      container.insertBefore(alerta, container.firstChild);

      setTimeout(() => alerta.remove(), 3000);
    };

    window.atualizarSyncStatus = function(conectado) {
      const dot = document.getElementById('syncDot');
      const text = document.getElementById('syncText');
      
      if (conectado) {
        dot.classList.remove('error');
        text.textContent = 'Conectado';
      } else {
        dot.classList.add('error');
        text.textContent = 'Desconectado';
      }
    };

  </script>

</body>
</html>
