<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Importador de Dados - Firebase</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Outfit', sans-serif;
      background: linear-gradient(135deg, #1b3a22 0%, #2c5c3a 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .container {
      background: #f6f2ea;
      border-radius: 12px;
      padding: 3rem;
      max-width: 600px;
      width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,.3);
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      color: #1b3a22;
      margin-bottom: .5rem;
    }

    .subtitle {
      font-size: .85rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #c8a84b;
      margin-bottom: 2rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    label {
      display: block;
      font-size: .8rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #1b3a22;
      margin-bottom: .6rem;
      font-weight: 500;
    }

    textarea {
      width: 100%;
      padding: 1rem;
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 6px;
      font-family: 'Courier New', monospace;
      font-size: .9rem;
      color: #252520;
      background: #ffffff;
      min-height: 300px;
      resize: vertical;
    }

    textarea:focus {
      outline: none;
      border-color: #c8a84b;
      box-shadow: 0 0 0 3px rgba(200,168,75,.1);
    }

    .btn {
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, #1b3a22 0%, #2c5c3a 100%);
      color: #ffffff;
      border: none;
      border-radius: 6px;
      font-size: .85rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-weight: 500;
      cursor: pointer;
      transition: all .3s;
      margin-bottom: 1rem;
    }

    .btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(27,58,34,.3);
    }

    .btn:disabled {
      opacity: .6;
      cursor: not-allowed;
    }

    .status {
      padding: 1rem;
      border-radius: 6px;
      margin-bottom: 1rem;
      font-size: .9rem;
      line-height: 1.6;
      display: none;
    }

    .status.show {
      display: block;
    }

    .status-success {
      background: rgba(37,211,102,.1);
      border: 1px solid rgba(37,211,102,.3);
      color: #1a7d4e;
    }

    .status-error {
      background: rgba(214,69,69,.1);
      border: 1px solid rgba(214,69,69,.3);
      color: #9a2c2c;
    }

    .status-loading {
      background: rgba(200,168,75,.1);
      border: 1px solid rgba(200,168,75,.3);
      color: #7a5230;
    }

    .info-box {
      background: rgba(200,168,75,.1);
      border: 1px solid rgba(200,168,75,.3);
      border-radius: 6px;
      padding: 1rem;
      margin-bottom: 2rem;
      font-size: .85rem;
      line-height: 1.6;
      color: #252520;
    }

    code {
      background: rgba(0,0,0,.05);
      padding: .2rem .4rem;
      border-radius: 3px;
      font-family: 'Courier New', monospace;
      font-size: .8rem;
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Importador de Dados</h1>
    <div class="subtitle">Firebase Firestore</div>

    <div class="info-box">
      ℹ️ Cole seu arquivo <code>dados.json</code> aqui para importar todos os dados (eventos, próxima gira, fotos e cursos) para o Firebase Firestore.
    </div>

    <div class="form-group">
      <label for="jsonInput">Cole o conteúdo do seu dados.json:</label>
      <textarea id="jsonInput" placeholder='Cole aqui o conteúdo completo do arquivo dados.json

Exemplo:
{
  "eventos": [...],
  "proximaGira": {...},
  "galeria": [...],
  "cursos": [...]
}'></textarea>
    </div>

    <button class="btn" onclick="importarDados()">📥 Importar Dados</button>

    <div id="status" class="status"></div>

    <div style="text-align: center; font-size: .75rem; color: #56564e; margin-top: 2rem;">
      ✅ Após importar, você pode acessar o painel em <code>admin.html</code>
    </div>
  </div>

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-app.js";
    import { getAuth } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-auth.js";
    import { getFirestore, collection, doc, setDoc, deleteDoc, getDocs } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-firestore.js";

    // Firebase Config
    const firebaseConfig = {
      apiKey: "AIzaSyCDt7n4hoxQlF0BRLWB_bBouO4A35YsZVY",
      authDomain: "mata-virgem.firebaseapp.com",
      projectId: "mata-virgem",
      storageBucket: "mata-virgem.firebasestorage.app",
      messagingSenderId: "351134240123",
      appId: "1:351134240123:web:86a041fee58b856ea3c1de",
      measurementId: "G-KM7DHTH737"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    window.importarDados = async function() {
      const textarea = document.getElementById('jsonInput');
      const statusDiv = document.getElementById('status');
      const btn = event.target;

      const jsonText = textarea.value.trim();

      if (!jsonText) {
        mostrarStatus('❌ Cole o JSON antes!', 'error');
        return;
      }

      btn.disabled = true;
      mostrarStatus('⏳ Importando dados...', 'loading');

      try {
        const dados = JSON.parse(jsonText);
        
        // Validar estrutura mínima
        if (!dados.eventos && !dados.proximaGira && !dados.galeria && !dados.cursos) {
          throw new Error('JSON inválido: faltam campos principais (eventos, proximaGira, galeria, cursos)');
        }

        // Limpar dados antigos
        mostrarStatus('⏳ Limpando dados antigos...', 'loading');
        
        // Deletar eventos antigos
        const eventosSnap = await getDocs(collection(db, 'eventos'));
        for (const doc of eventosSnap.docs) {
          await deleteDoc(doc.ref);
        }

        // Deletar galeria antiga
        const galeriaSnap = await getDocs(collection(db, 'galeria'));
        for (const doc of galeriaSnap.docs) {
          await deleteDoc(doc.ref);
        }

        // Importar Eventos
        if (dados.eventos && Array.isArray(dados.eventos)) {
          mostrarStatus(`⏳ Importando ${dados.eventos.length} eventos...`, 'loading');
          for (const evento of dados.eventos) {
            const id = evento.id || Date.now().toString();
            await setDoc(doc(db, 'eventos', id), {
              dia: evento.dia,
              mes: evento.mes,
              semana: evento.semana,
              nome: evento.nome,
              hora: evento.hora
            });
          }
        }

        // Importar Próxima Gira
        if (dados.proximaGira && typeof dados.proximaGira === 'object') {
          mostrarStatus('⏳ Importando próxima gira...', 'loading');
          await setDoc(doc(db, 'proximaGira', 'gira1'), {
            data: dados.proximaGira.data,
            dia: dados.proximaGira.dia,
            hora: dados.proximaGira.hora,
            nome: dados.proximaGira.nome,
            descricao: dados.proximaGira.descricao,
            imagem: dados.proximaGira.imagem
          });
        }

        // Importar Galeria
        if (dados.galeria && Array.isArray(dados.galeria)) {
          mostrarStatus(`⏳ Importando ${dados.galeria.length} fotos...`, 'loading');
          for (const foto of dados.galeria) {
            const id = foto.id || Date.now().toString();
            await setDoc(doc(db, 'galeria', id), {
              titulo: foto.titulo,
              url: foto.url
            });
          }
        }

        // Importar Cursos
        if (dados.cursos && Array.isArray(dados.cursos)) {
          mostrarStatus('⏳ Importando cursos...', 'loading');
          const aulas = dados.cursos[0]?.aulas || [];
          await setDoc(doc(db, 'cursos', 'curso1'), {
            aulas: aulas
          });
        }

        btn.disabled = false;
        mostrarStatus('✅ Dados importados com sucesso! Acesse admin.html para editar.', 'success');
        
        // Limpar input
        setTimeout(() => {
          textarea.value = '';
        }, 1000);

      } catch (erro) {
        btn.disabled = false;
        console.error('Erro:', erro);
        mostrarStatus(`❌ Erro: ${erro.message}`, 'error');
      }
    };

    function mostrarStatus(msg, tipo) {
      const statusDiv = document.getElementById('status');
      statusDiv.innerHTML = msg;
      statusDiv.className = `status show status-${tipo}`;
    }
  </script>

</body>
</html>
